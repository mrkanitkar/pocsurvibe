{
  "permissions": {
    "allow": [
      "mcp__XcodeBuildMCP__*",
      "mcp__xcode__*",
      "mcp__apple-docs__*",
      "Read",
      "Glob",
      "Grep",
      "Bash(swift *)",
      "Bash(swiftlint *)",
      "Bash(xcrun *)",
      "Bash(xcodebuild *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/Secrets.swift)",
      "Write(.env*)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/swift-format-lint.sh"
          }
        ]
      }
    ]
  }
}
